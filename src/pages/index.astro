---
import BaseLayout from "../layouts/BaseLayout.astro";
import AnimatedHome from "../components/home/AnimatedHome";
import blogMeta from "../content/blog/_meta.json";
import diaryMeta from "../content/diary/_meta.json";
import projectMeta from "../content/projects/_meta.json";
import achievementMeta from "../content/achievements/_meta.json";

type MetaItem = {
  id: string;
  slug: string;
  title: string;
  date: string;
  description?: string;
};

const essays = (blogMeta as MetaItem[]).slice(0, 5);
const diaries = (diaryMeta as MetaItem[]).slice(0, 2);
const projects = (projectMeta as MetaItem[]).slice(0, 3);
const achievements = (achievementMeta as MetaItem[]).slice(0, 3);
const timeline = [
  ...essays.slice(0, 3).map((item) => ({ ...item, type: "思考", href: `/essays/${item.slug}/` })),
  ...diaries.slice(0, 2).map((item) => ({ ...item, title: "日记记录", type: "日记", href: `/diaries/${item.slug}/` }))
].sort((a, b) => (a.date < b.date ? 1 : a.date > b.date ? -1 : 0)).slice(0, 4);
---

<BaseLayout>
  <AnimatedHome
    client:load
    essays={essays}
    diaries={diaries}
    projects={projects}
    achievements={achievements}
    timeline={timeline}
  />
</BaseLayout>
