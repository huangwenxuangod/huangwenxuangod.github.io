---
import BaseLayout from "../layouts/BaseLayout.astro";
import blogMeta from "../content/blog/_meta.json";
import diaryMeta from "../content/diary/_meta.json";
import projectMeta from "../content/projects/_meta.json";
import achievementMeta from "../content/achievements/_meta.json";

type MetaItem = {
  id: string;
  slug: string;
  title: string;
  date: string;
  description?: string;
};

const essays = (blogMeta as MetaItem[]).slice(0, 5);
const diaries = (diaryMeta as MetaItem[]).slice(0, 2);
const projects = (projectMeta as MetaItem[]).slice(0, 3);
const achievements = (achievementMeta as MetaItem[]).slice(0, 3);

function formatDateDot(ymd: string): string {
  const [y, m, d] = ymd.split("-");
  return `${y}.${m}.${d}`;
}
---

<BaseLayout>
  <section class="home-shell">
    <div class="hero-panel">
      <div class="hero-kicker">Personal archive / systems in public</div>
      <h1>把思考、项目和结果，整理成一条可见的自由之路。</h1>
      <p>
        这里记录我对 AI、内容、产品和个人商业模式的长期实验。文章负责解释世界，项目负责推进现实，成果负责证明路径。
      </p>
      <div class="hero-actions">
        <a href="/projects" class="primary-link">看项目</a>
        <a href="/essays" class="secondary-link">读思考</a>
      </div>
    </div>

    <section class="signal-strip" aria-label="当前关注">
      <span>AI 产品化</span>
      <span>内容系统</span>
      <span>自动化工作流</span>
      <span>个人商业模式</span>
    </section>

    <div class="home-grid">
      <section class="feature-section">
        <div class="section-heading">
          <span>成果</span>
          <a href="/achievements">全部</a>
        </div>
        {
          achievements.length > 0 ? (
            <div class="stack-list">
              {achievements.map((item) => (
                <a class="feature-card" href={`/achievements/${item.slug}/`}>
                  <span class="item-date">{formatDateDot(item.date)}</span>
                  <strong>{item.title}</strong>
                  {item.description && <p>{item.description}</p>}
                </a>
              ))}
            </div>
          ) : (
            <div class="empty-panel">
              <span>成果档案位</span>
              <p>后续放可验证的结果、数据、截图和复盘。</p>
            </div>
          )
        }
      </section>

      <section class="feature-section">
        <div class="section-heading">
          <span>项目</span>
          <a href="/projects">全部</a>
        </div>
        {
          projects.length > 0 ? (
            <div class="stack-list">
              {projects.map((item) => (
                <a class="feature-card" href={`/projects/${item.slug}/`}>
                  <span class="item-date">{formatDateDot(item.date)}</span>
                  <strong>{item.title}</strong>
                  {item.description && <p>{item.description}</p>}
                </a>
              ))}
            </div>
          ) : (
            <div class="empty-panel">
              <span>项目档案位</span>
              <p>这里会展示系统、实验、产品原型和长期推进的事。</p>
            </div>
          )
        }
      </section>
    </div>

    <section class="archive-section">
      <div class="section-heading">
        <span>最新思考</span>
        <a href="/essays">全部</a>
      </div>
      <div class="archive-list">
        {
          essays.map((post) => (
            <a class="post-row" href={`/essays/${post.slug}/`}>
              <span class="post-date">{formatDateDot(post.date)}</span>
              <span class="post-title">{post.title}</span>
              <span class="post-arrow">→</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="diary-rail">
      <div>
        <span class="rail-label">Diary</span>
        <p>没有整理成文章的真实过程，保留原始颗粒度。</p>
      </div>
      <div class="diary-links">
        {
          diaries.map((post) => (
            <a href={`/diaries/${post.slug}/`}>{formatDateDot(post.date)}</a>
          ))
        }
        <a href="/diaries">进入日记 →</a>
      </div>
    </section>
  </section>
</BaseLayout>
