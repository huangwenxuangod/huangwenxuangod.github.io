---
import BaseLayout from "../layouts/BaseLayout.astro";
import blogMeta from "../content/blog/_meta.json";
import diaryMeta from "../content/diary/_meta.json";
import projectMeta from "../content/projects/_meta.json";
import achievementMeta from "../content/achievements/_meta.json";

type MetaItem = {
  id: string;
  slug: string;
  title: string;
  date: string;
  description?: string;
};

const essays = (blogMeta as MetaItem[]).slice(0, 5);
const diaries = (diaryMeta as MetaItem[]).slice(0, 2);
const projects = (projectMeta as MetaItem[]).slice(0, 3);
const achievements = (achievementMeta as MetaItem[]).slice(0, 3);
const timeline = [
  ...essays.slice(0, 3).map((item) => ({ ...item, type: "思考", href: `/essays/${item.slug}/` })),
  ...diaries.slice(0, 2).map((item) => ({ ...item, title: "日记记录", type: "日记", href: `/diaries/${item.slug}/` }))
].sort((a, b) => (a.date < b.date ? 1 : a.date > b.date ? -1 : 0)).slice(0, 4);

function formatDateDot(ymd: string): string {
  const [y, m, d] = ymd.split("-");
  return `${y}.${m}.${d}`;
}
---

<BaseLayout>
  <section class="home-shell editorial-home">
    <section class="poster-stage">
      <div class="poster-aside">
        <span>WX ROAD / 001</span>
        <span>AI · CONTENT · PRODUCT</span>
      </div>

      <div class="poster-copy">
        <div class="hero-kicker">Personal archive / systems in public</div>
        <h1 class="poster-title">
          <span>自由不是</span>
          <span>等来的路，</span>
          <span>是一步一步</span>
          <span>走出来的路。</span>
        </h1>
        <p>
          这里记录我把想法推进成项目、把项目沉淀成成果、再把过程写回思考的长期实验。
        </p>
        <div class="poster-actions">
          <a href="/essays">读思考</a>
          <a href="/projects">看项目</a>
          <a href="/achievements">看成果</a>
        </div>
      </div>

      <div class="poster-note">
        <span>NOW</span>
        <p>AI 产品化 / 内容系统 / 自动化工作流 / 个人商业模式</p>
      </div>
    </section>

    <section class="timeline-strip" aria-label="最近记录">
      <div class="section-code">
        <span>Timeline</span>
        <strong>最近留下的脚印</strong>
      </div>
      <div class="timeline-list">
        {
          timeline.map((item) => (
            <a class="timeline-item" href={item.href}>
              <span>{formatDateDot(item.date)}</span>
              <strong>{item.title}</strong>
              <em>{item.type}</em>
            </a>
          ))
        }
      </div>
    </section>

    <div class="ledger-grid">
      <section class="ledger-panel result-panel">
        <div class="section-code">
          <span>Result file</span>
          <strong>成果</strong>
        </div>
        {
          achievements.length > 0 ? (
            <div class="ledger-list">
              {achievements.map((item) => (
                <a class="ledger-row" href={`/achievements/${item.slug}/`}>
                  <span>{formatDateDot(item.date)}</span>
                  <strong>{item.title}</strong>
                </a>
              ))}
            </div>
          ) : (
            <div class="file-placeholder">
              <span>RESULT SLOT</span>
              <strong>可验证的结果会放在这里。</strong>
              <p>数据、截图、发布记录、增长结果和复盘。</p>
            </div>
          )
        }
      </section>

      <section class="ledger-panel project-panel">
        <div class="section-code">
          <span>Project file</span>
          <strong>项目</strong>
        </div>
        {
          projects.length > 0 ? (
            <div class="ledger-list">
              {projects.map((item) => (
                <a class="ledger-row" href={`/projects/${item.slug}/`}>
                  <span>{formatDateDot(item.date)}</span>
                  <strong>{item.title}</strong>
                </a>
              ))}
            </div>
          ) : (
            <div class="file-placeholder">
              <span>PROJECT SLOT</span>
              <strong>正在推进的系统会放在这里。</strong>
              <p>背景、动作、结构图、结果和下一步。</p>
            </div>
          )
        }
      </section>
    </div>

    <section class="archive-section">
      <div class="section-heading">
        <span>最新思考</span>
        <a href="/essays">全部</a>
      </div>
      <div class="archive-list">
        {
          essays.map((post) => (
            <a class="post-row" href={`/essays/${post.slug}/`}>
              <span class="post-date">{formatDateDot(post.date)}</span>
              <span class="post-title">{post.title}</span>
              <span class="post-arrow">→</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="diary-rail">
      <div>
        <span class="rail-label">Diary</span>
        <p>日记像路上的灰尘，不一定漂亮，但能证明自己真的走过。</p>
      </div>
      <div class="diary-links">
        {
          diaries.map((post) => (
            <a href={`/diaries/${post.slug}/`}>{formatDateDot(post.date)}</a>
          ))
        }
        <a href="/diaries">进入日记 →</a>
      </div>
    </section>
  </section>
</BaseLayout>
