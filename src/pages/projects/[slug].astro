---
import BaseLayout from "../../layouts/BaseLayout.astro";
import meta from "../../content/projects/_meta.json";
import { getCollection } from "astro:content";

type MetaItem = {
  id: string;
  slug: string;
  title: string;
  date: string;
  description?: string;
};

function formatDateMid(ymd: string) {
  const [y, m, d] = ymd.split("-");
  return `${y} · ${m} · ${d}`;
}

export async function getStaticPaths() {
  const posts = meta as MetaItem[];
  return posts.map((p) => ({ params: { slug: p.slug }, props: { id: p.id } }));
}

const { id } = Astro.props as { id: string };
const collection = await getCollection("projects");
const entry = collection.find((e) => e.id === id);

if (!entry) {
  throw new Error(`Missing project entry for id: ${id}`);
}

const m = (meta as MetaItem[]).find((p) => p.id === id);
const { Content } = await entry.render();
---

<BaseLayout title={m?.title} description={m?.description}>
  <article class="article-wrap case-wrap">
    <div class="article-topline">
      <a href="/projects" class="back-btn">
        <svg viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M5 1L1 5l4 4M1 5h10" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        返回项目
      </a>
    </div>

    <div class="article-meta">{formatDateMid(m?.date ?? "0000-00-00")}</div>
    <h1 class="article-title">{m?.title ?? entry.data.title}</h1>

    <div class="figure-placeholder">
      <span>示意图位置</span>
      <small>流程图 / 截图 / 架构图 / 产品界面</small>
    </div>

    <div class="article-body">
      <Content />
    </div>
  </article>
</BaseLayout>
