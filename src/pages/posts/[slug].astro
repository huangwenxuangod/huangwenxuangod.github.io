---
import BaseLayout from "../../layouts/BaseLayout.astro";
import meta from "../../content/blog/_meta.json";
import { getCollection } from "astro:content";

type MetaItem = {
  id: string;
  slug: string;
  title: string;
  date: string;
  description?: string;
};

function formatDateMid(ymd: string) {
  const [y, m, d] = ymd.split("-");
  return `${y} · ${m} · ${d}`;
}

export async function getStaticPaths() {
  const posts = meta as MetaItem[];
  return posts.map((p) => ({ params: { slug: p.slug }, props: { id: p.id } }));
}

const { id } = Astro.props as { id: string };
const collection = await getCollection("blog");
const entry = collection.find((e) => e.id === id);

if (!entry) {
  throw new Error(`Missing blog entry for id: ${id}`);
}

const m = (meta as MetaItem[]).find((p) => p.id === id);
const { Content } = await entry.render();

const all = meta as MetaItem[];
const currentIndex = all.findIndex((p) => p.id === id);
const prev = currentIndex >= 0 ? all[currentIndex + 1] : undefined;
const next = currentIndex >= 0 ? all[currentIndex - 1] : undefined;
---
<BaseLayout title={m?.title} description={m?.description}>
  <div class="article-wrap">
    <div style="margin-bottom: 32px;">
      <a href="/" class="back-btn">
        <svg viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M5 1L1 5l4 4M1 5h10" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        返回
      </a>
    </div>

    <div class="article-meta">{formatDateMid(m?.date ?? "0000-00-00")}</div>
    <h1 class="article-title">{m?.title ?? entry.data.title ?? "未命名"}</h1>

    <div class="article-body">
      <Content />
    </div>

    {(prev || next) && (
      <nav class="post-nav" aria-label="文章导航">
        {next && (
          <a href={`/posts/${next.slug}/`}>
            <span class="nav-label">上一篇</span>
            {next.title}
          </a>
        )}
        {prev && (
          <a href={`/posts/${prev.slug}/`} class="nav-next">
            <span class="nav-label">下一篇</span>
            {prev.title}
          </a>
        )}
      </nav>
    )}
  </div>
</BaseLayout>

